{
  "name": "@tomato-form/website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3021",
    "build": "next build",
    "start": "next start --port 3021",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "rm -rf .next"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/react": "^0.5.0",

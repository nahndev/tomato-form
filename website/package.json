    "@tailwindcss/postcss": "^4.3.0",
    "@tanstack/react-query": "^5.28.0",
    "axios": "^1.17.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cron-parser": "^4.9.0",
    "formik": "^2.4.6",
    "fractional-indexing": "^3.2.0",
    "lexical": "^0.46.0",
    "lucide-react": "^0.378.0",
    "motion": "^12.40.0",
    "next": "^15.1.0",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-use": "^17.6.1",
    "remeda": "^2.39.0",
    "shadcn": "^4.10.0",
    "socket.io-client": "^4.7.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.1",
    "tw-animate-css": "^1.4.0",
